{
	"name": "@akuseru_w/kura",
	"version": "0.1.9",
	"description": "A Bun-native TypeScript web framework.",
	"keywords": [
		"bun",
		"framework",
		"http",
		"typescript",
		"kura"
	],
	"homepage": "https://github.com/AkuseruW/kura#readme",
	"bugs": {
		"url": "https://github.com/AkuseruW/kura/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AkuseruW/kura.git"
	},
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"files": [
		"dist"
	],
	"bin": {
		"kura": "dist/bin/kura.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.3.0"
	},
	"scripts": {
		"bench:run": "bun run benchmarks/scripts/run.ts",
		"bench:scaffold": "bun run benchmarks/scripts/scaffold.ts",
		"build": "bun run scripts/build.ts",
		"lint": "biome check .",
		"format": "biome format . --write",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@types/bun": "^1.3.6",
		"lefthook": "^2.0.15",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"peerDependenciesMeta": {
		"typescript": {
			"optional": true
		}
	}
}
