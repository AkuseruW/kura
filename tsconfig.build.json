{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "dist"
	},
	"include": ["index.ts", "bin/kura.ts", "packages/**/*.ts"],
	"exclude": [
		"dist",
		"node_modules",
		"scripts",
		"packages/create-kurajs",
		"**/*.test.ts"
	]
}
