{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "dist"
	},
	"include": ["*.ts", "bin/kura.ts", "packages/**/*.ts", "queue/**/*.ts"],
	"exclude": [
		"dist",
		"node_modules",
		"scripts",
		"packages/create-kura-app",
		"**/*.test.ts"
	]
}
